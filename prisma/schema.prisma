generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int               @id @default(autoincrement())
  username     String            @unique
  email        String?           @unique
  passwordHash String
  isAdmin      Boolean           @default(false)
  timezone     String            @default("Europe/Bucharest")
  theme        Theme             @default(DARK)
  predictionReminderEnabled Boolean               @default(false)
  createdAt    DateTime          @default(now())
  predictions  Prediction[]
  advances     KnockoutAdvance[]
  championships             ChampionshipMember[]
  managedChampionships      ChampionshipManager[]
  generatedInvites          ChampionshipInvite[]
  passwordResetTokens       PasswordResetToken[]
  predictionReminders       PredictionReminder[]
}

model Championship {
  id                  Int                  @id @default(autoincrement())
  name                String               @unique
  description         String               @default("")
  isActive            Boolean              @default(true)
  doubleChanceEnabled Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  members             ChampionshipMember[]
  managers            ChampionshipManager[]
  invites             ChampionshipInvite[]
  predictionReminders PredictionReminder[]
}

model ChampionshipMember {
  championshipId Int
  userId         Int
  createdAt      DateTime     @default(now())
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([championshipId, userId])
}

model ChampionshipManager {
  championshipId Int
  userId         Int
  createdAt      DateTime     @default(now())
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([championshipId, userId])
}

model ChampionshipInvite {
  id             Int          @id @default(autoincrement())
  championshipId Int
  tokenHash      String       @unique
  createdById    Int
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([championshipId, revokedAt])
}

model Match {
  id                         Int               @id @default(autoincrement())
  externalId                 String            @unique
  homeTeam                   String
  awayTeam                   String
  homeTeamCrest              String            @default("")
  awayTeamCrest              String            @default("")
  stage                      Stage
  group                      String?
  kickoff                    DateTime
  status                     MatchStatus       @default(SCHEDULED)
  scoreDuration              String            @default("REGULAR")
  homeScore                  Int?
  awayScore                  Int?
  winnerTeam                 String?
  adminOverride              Boolean           @default(false)
  headToHeadHomeTeamId       String?
  headToHeadAwayTeamId       String?
  headToHeadJson             String            @default("[]")
  headToHeadSyncedAt         DateTime?
  predictions                Prediction[]
  advances                   KnockoutAdvance[]
  predictionReminders        PredictionReminder[]
  events                     MatchEvent[]
  teamStats                  MatchTeamStat[]
}

model Team {
  id                      Int    @id @default(autoincrement())
  externalId              String @unique
  name                    String
  shortName               String
  tla                     String @default("")
  crest                   String
  areaName                String @default("")
  areaCode                String @default("")
  address                 String @default("")
  website                 String @default("")
  founded                 Int?
  clubColors              String @default("")
  venue                   String @default("")
  coachName               String @default("")
  squadJson               String @default("[]")
  staffJson               String @default("[]")
  runningCompetitionsJson String @default("[]")
  rawJson                 String @default("{}")
}

model Prediction {
  id             Int            @id @default(autoincrement())
  userId         Int
  matchId        Int
  championshipId Int
  type           PredictionType
  value          String
  pointsAwarded  Int?
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  match          Match          @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId, type, championshipId])
  @@index([matchId, championshipId])
}

model KnockoutAdvance {
  id             Int      @id @default(autoincrement())
  userId         Int
  matchId        Int
  championshipId Int
  predictedTeam  String
  pointsAwarded  Int?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match          Match    @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId, championshipId])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PredictionReminder {
  id             Int          @id @default(autoincrement())
  userId         Int
  matchId        Int
  championshipId Int
  sentAt         DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  match          Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, championshipId])
  @@index([matchId])
}

model MatchEvent {
  id                Int            @id @default(autoincrement())
  matchId           Int
  type              MatchEventType
  minute            Int
  teamName          String
  playerName        String         @default("")
  relatedPlayerName String         @default("")
  createdAt         DateTime       @default(now())
  match             Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, type, minute, teamName, playerName, relatedPlayerName])
  @@index([type])
  @@index([teamName])
}

model MatchTeamStat {
  id       Int               @id @default(autoincrement())
  matchId  Int
  teamName String
  type     MatchTeamStatType
  value    Int
  match    Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamName, type])
  @@index([type])
}

model AdminAuditLog {
  id            Int      @id @default(autoincrement())
  adminId       Int
  adminUsername String
  action        String
  entityType    String?
  entityId      String?
  details       String?
  createdAt     DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

enum Stage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum PredictionType {
  SINGLE_OUTCOME
  DOUBLE_CHANCE
  EXACT_SCORE
}

enum Theme {
  DARK
  LIGHT
}

enum MatchEventType {
  GOAL
  YELLOW_CARD
  RED_CARD
  YELLOW_RED_CARD
  FOUL
  CORNER
}

enum MatchTeamStatType {
  FOULS
  CORNERS
}
