generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int               @id @default(autoincrement())
  username     String            @unique
  email        String?           @unique
  passwordHash String
  isAdmin      Boolean           @default(false)
  timezone     String            @default("Europe/Bucharest")
  theme        Theme             @default(DARK)
  createdAt    DateTime          @default(now())
  predictions  Prediction[]
  advances     KnockoutAdvance[]
  championships ChampionshipMember[]
  managedChampionships ChampionshipManager[]
  generatedInvites ChampionshipInvite[]
  passwordResetTokens PasswordResetToken[]
}

model Championship {
  id                  Int                  @id @default(autoincrement())
  name                String               @unique
  description         String               @default("")
  isActive            Boolean              @default(true)
  doubleChanceEnabled Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  members             ChampionshipMember[]
  managers            ChampionshipManager[]
  invites             ChampionshipInvite[]
}

model ChampionshipMember {
  championshipId Int
  userId         Int
  createdAt      DateTime     @default(now())
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([championshipId, userId])
}

model ChampionshipManager {
  championshipId Int
  userId         Int
  createdAt      DateTime     @default(now())
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([championshipId, userId])
}

model ChampionshipInvite {
  id             Int          @id @default(autoincrement())
  championshipId Int
  tokenHash      String       @unique
  createdById    Int
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  championship   Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  createdBy      User         @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([championshipId, revokedAt])
}

model Match {
  id                         Int               @id @default(autoincrement())
  externalId                 String            @unique
  homeTeam                   String
  awayTeam                   String
  homeTeamCrest              String            @default("")
  awayTeamCrest              String            @default("")
  stage                      Stage
  group                      String?
  kickoff                    DateTime
  status                     MatchStatus       @default(SCHEDULED)
  homeScore                  Int?
  awayScore                  Int?
  winnerTeam                 String?
  adminOverride              Boolean           @default(false)
  headToHeadHomeTeamId       String?
  headToHeadAwayTeamId       String?
  headToHeadJson             String            @default("[]")
  headToHeadSyncedAt         DateTime?
  predictions                Prediction[]
  advances                   KnockoutAdvance[]
}

model Team {
  id                      Int    @id @default(autoincrement())
  externalId              String @unique
  name                    String
  shortName               String
  tla                     String @default("")
  crest                   String
  areaName                String @default("")
  areaCode                String @default("")
  address                 String @default("")
  website                 String @default("")
  founded                 Int?
  clubColors              String @default("")
  venue                   String @default("")
  coachName               String @default("")
  squadJson               String @default("[]")
  staffJson               String @default("[]")
  runningCompetitionsJson String @default("[]")
  rawJson                 String @default("{}")
}

model Prediction {
  id             Int            @id @default(autoincrement())
  userId         Int
  matchId        Int
  championshipId Int
  type           PredictionType
  value          String
  pointsAwarded  Int?
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  match          Match          @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId, type, championshipId])
}

model KnockoutAdvance {
  id             Int      @id @default(autoincrement())
  userId         Int
  matchId        Int
  championshipId Int
  predictedTeam  String
  pointsAwarded  Int?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match          Match    @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId, championshipId])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Stage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum PredictionType {
  SINGLE_OUTCOME
  DOUBLE_CHANCE
  EXACT_SCORE
}

enum Theme {
  DARK
  LIGHT
}
